import customtkinter as ctk
from tkinter import messagebox

class AuthScreens:
    def __init__(self, root, auth_manager, on_login_success):
        self.root = root
        self.auth_manager = auth_manager
        self.on_login_success = on_login_success
        self.show_login()

    def clear_screen(self):
        for widget in self.root.winfo_children():
            widget.destroy()

    def show_login(self):
        self.clear_screen()
        frame = ctk.CTkFrame(self.root, width=400, height=500)
        frame.place(relx=0.5, rely=0.5, anchor="center")

        ctk.CTkLabel(frame, text="AI Trip Planner", font=("Helvetica", 24, "bold")).pack(pady=30)
        ctk.CTkLabel(frame, text="Login to your account").pack(pady=5)

        self.user_entry = ctk.CTkEntry(frame, placeholder_text="Username", width=250)
        self.user_entry.pack(pady=10)

        self.pass_entry = ctk.CTkEntry(frame, placeholder_text="Password", show="*", width=250)
        self.pass_entry.pack(pady=10)

        ctk.CTkButton(frame, text="Login", command=self.handle_login, width=250).pack(pady=20)
        ctk.CTkButton(frame, text="Create Account", fg_color="transparent", border_width=1, 
                      command=self.show_signup, width=250).pack(pady=10)

    def handle_login(self):
        u, p = self.user_entry.get(), self.pass_entry.get()
        success, msg = self.auth_manager.login(u, p)
        if success:
            self.on_login_success()
        else:
            messagebox.showerror("Error", msg)

    def show_signup(self):
        self.clear_screen()
        frame = ctk.CTkFrame(self.root, width=400, height=600)
        frame.place(relx=0.5, rely=0.5, anchor="center")

        ctk.CTkLabel(frame, text="Create Account", font=("Helvetica", 24, "bold")).pack(pady=30)

        self.s_user = ctk.CTkEntry(frame, placeholder_text="Username", width=250)
        self.s_user.pack(pady=10)

        self.s_email = ctk.CTkEntry(frame, placeholder_text="Email", width=250)
        self.s_email.pack(pady=10)

        self.s_pass = ctk.CTkEntry(frame, placeholder_text="Password", show="*", width=250)
        self.s_pass.pack(pady=10)

        ctk.CTkButton(frame, text="Sign Up", command=self.handle_signup, width=250).pack(pady=20)
        ctk.CTkButton(frame, text="Back to Login", fg_color="transparent", border_width=1, 
                      command=self.show_login, width=250).pack(pady=10)

    def handle_signup(self):
        u, e, p = self.s_user.get(), self.s_email.get(), self.s_pass.get()
        if not u or not e or not p:
            messagebox.showwarning("Warning", "All fields are required")
            return
        success, msg = self.auth_manager.signup(u, p, e)
        if success:
            messagebox.showinfo("Success", msg)
            self.show_login()
        else:
            messagebox.showerror("Error", msg)
